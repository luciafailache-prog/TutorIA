rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'createdAt']) 
             && data.userId == request.auth.uid 
             && data.name is string && data.name.size() <= 100
             && data.email is string && data.email.size() <= 100
             && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 500))
             && data.badges is list;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'avatar', 'badges']);
    }

    // --- Topics (Knowledge Base) ---
    match /topics/{topicId} {
      allow read: if isSignedIn();
      // Only admin (docente) should write, but for this demo students can't.
      // We'll seed this via a service or manual write if needed.
      allow write: if false; 
    }

    // --- Progress ---
    match /progress/{progressId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- Exercises ---
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    // --- Submissions ---
    match /submissions/{submissionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Badges ---
    match /badges/{badgeId} {
      allow read: if isSignedIn();
    }
  }
}
